# Database
DATABASE_URL=postgresql://gojump:gojump_secure_pass@localhost:5432/gojump_sms
POSTGRES_USER=gojump
POSTGRES_PASSWORD=gojump_secure_pass
POSTGRES_DB=gojump_sms

# Auth
JWT_SECRET=supersecretjwtkey_change_in_production_min32chars

# Server
PORT=4000
